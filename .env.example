# Runtime
TZ=Asia/Shanghai

# Pinduoduo / 多多买菜后台
PDD_ORDER_MANAGEMENT_URL=https://mc.pinduoduo.com/ddmc-mms/order/management
PDD_BROWSER_PROFILE_DIR=.cache/pdd-chrome-profile
# Optional. Use installed Chrome instead of bundled Chromium during local/server debugging.
# Common value: chrome
PDD_BROWSER_CHANNEL=
PDD_CHROMIUM_SANDBOX=true

# Optional advanced mode. If set, the script connects to an already-running Chrome instead of launching one.
# Start Chrome separately with:
# /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --remote-debugging-port=9222 --user-data-dir=/tmp/pdd-debug-profile
PDD_CDP_URL=
PDD_HEADLESS=false
PDD_MAX_PAGES=20
PDD_TARGET_PAGE_SIZE=100
PDD_SELECT_YESTERDAY=true
PDD_WAIT_FOR_LOGIN=true
PDD_SYNC_MODE=dom
PDD_STORAGE_STATE=data/pdd-storage-state.json
# API mode: login with Playwright, save storageState, then call PDD endpoints through BrowserContext.request.
# Use `pnpm run pdd:api-probe` first to capture the exact request body/headers if the default body does not work.
PDD_APPOINTMENT_GOODS_BODY_JSON=
PDD_API_WAREHOUSE_IDS=
PDD_API_EXTRA_HEADERS_JSON=
PDD_ANTI_CONTENT=
PDD_API_SNAPSHOT_JSON=data/pdd/latest-api-response.json
PDD_API_PROBE_MS=60000
PDD_API_PROBE_JSON=data/pdd-api-probe.json

# Optional. Prefer first-run manual login with saved browser profile.
# Only use these if you later decide to automate normal login fields.
PDD_USERNAME=
PDD_PASSWORD=

# Local output. Website can read the JSON file.
PDD_OUTPUT_DIR=data/pdd
PDD_LATEST_JSON=data/latest.json
PDD_LATEST_CSV=data/latest.csv
PDD_FEISHU_FALLBACK_DIR=data/feishu-fallback
PDD_FEISHU_FALLBACK_LATEST_CSV=data/feishu-fallback/appointment-feishu-latest.csv

# Feishu OpenAPI
# Create a Feishu self-built app, add Sheets permissions, then fill these.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# PDD screenshot report. Per-warehouse rules are managed in the web UI and saved as JSON.
# The bot must already be in every target group.
FEISHU_REPORT_CHAT_NAME=多多数字管家群
FEISHU_REPORT_MENTION_NAME=鑫
# Optional when names are duplicated or group/member list permissions are unavailable.
FEISHU_REPORT_CHAT_ID=
FEISHU_REPORT_MENTION_OPEN_ID=
PDD_REPORT_HEADLESS=false
PDD_REPORT_OUTPUT_DIR=data/reports
PDD_REPORT_CONFIG_PATH=data/report-config.json

# WeChat (Wechaty) group report
# The bot runs inside the web server; scan QR code in the web UI to log in.
# Windows uses Wechaty by default. Turn this on only when a Windows machine cannot run Wechaty and should operate the desktop WeChat App instead.
MAO_USE_DESKTOP_WECHAT=false
# Optional. Leave empty for auto-detect; set this when Weixin.exe/WeChat.exe is installed in a custom path.
MAO_WECHAT_EXE_PATH=
WECHATY_AUTO_START=false
# Required. Use a dedicated Chrome/profile so Wechaty never touches PDD Playwright on 9222.
# Start it once with:
# open -na "Google Chrome" --args --remote-debugging-port=9333 --user-data-dir=/tmp/wechaty-debug-profile
WECHATY_CDP_URL=http://127.0.0.1:9333
# Internal bridge URL for the reporter child process to call the Wechaty bot.
WECHAT_BRIDGE_URL=http://127.0.0.1:4173

# Spreadsheet target.
# Recommended: use the wiki link you share with the app. The sync will resolve it to the real spreadsheet token.
FEISHU_WIKI_URL=https://xcn413dmlc7m.feishu.cn/wiki/EChawQEHEipllvkxqMycZL3Yn7c
FEISHU_WIKI_NODE_TOKEN=EChawQEHEipllvkxqMycZL3Yn7c
FEISHU_KANBAN_RAW_URL=https://xcn413dmlc7m.feishu.cn/wiki/EChawQEHEipllvkxqMycZL3Yn7c
FEISHU_KANBAN_RULES_URL=https://xcn413dmlc7m.feishu.cn/wiki/VY6Pw5l9piRdzIk3mQ4c5icrnib
FEISHU_KANBAN_MANUAL_URL=https://xcn413dmlc7m.feishu.cn/wiki/FKy1wkDScizSZMknuK7cegQXnZs
# Where kanban review sheets are written. Can also be changed in /kanban.html.
FEISHU_KANBAN_REVIEW_URL=https://xcn413dmlc7m.feishu.cn/wiki/H4QTwsAcJiUzZ5kaHr9cMJHpnCc
FEISHU_KANBAN_WRITEBACK=true
FEISHU_KANBAN_MANUAL_SYNC=true

# Optional fallback if you want to bypass wiki resolution later.
FEISHU_SPREADSHEET_TOKEN=
FEISHU_SHEET_ID=
FEISHU_START_CELL=A1
FEISHU_DAILY_SHEET_NAME_FORMAT=YYYY-MM-DD

# Extra blank rows written after the data to clear stale rows from prior longer syncs.
FEISHU_CLEAR_EXTRA_ROWS=200
# Keep false so local Feishu-compatible CSV is the fallback when Feishu/network fails.
FEISHU_STRICT_WRITE=false

# Daily schedule target. Configure cron/launchd/systemd to run the sync command at this time.
SYNC_TIME=08:30
